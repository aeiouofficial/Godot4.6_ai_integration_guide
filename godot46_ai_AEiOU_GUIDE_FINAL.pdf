BT 1 0 0 1 0 107.5 Tm /F3 7.5 Tf 11.5 TL (import asyncio from provider_gemini import gemini_complete from provider_glm import glm_complete async) Tj T* (def race_providers\( prompt: str, timeout: float = 5.0, \) -> dict: """ Fire Gemini and GLM-5) Tj T* (simultaneously. Use whichever responds first. Cancel the loser. Cost: slightly higher \(both providers) Tj T* (bill for partial work\). Benefit: guaranteed response within 5s regardless of which provider is slow. Best) Tj T* (for: real-time NPC dialogue where latency > cost. """ tasks = {) Tj T* (asyncio.create_task\(gemini_complete\(prompt, thinking="none"\), name="gemini"\): "gemini",) Tj T* (asyncio.create_task\(glm_complete\(prompt, thinking=False\), name="glm-5"\): "glm-5", } try: done, pending =) Tj T* (await asyncio.wait\( tasks.keys\(\), return_when=asyncio.FIRST_COMPLETED, timeout=timeout, \) except) Tj T* (asyncio.TimeoutError: for t in tasks: t.cancel\(\) raise for t in pending: t.cancel\(\) winner =) Tj T* (next\(iter\(done\)\) return {"provider": tasks[winner], "result": winner.result\(\)}) Tj T* ET
