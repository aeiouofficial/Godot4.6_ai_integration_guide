BT 1 0 0 1 0 199.5 Tm /F3 7.5 Tf 11.5 TL (import re, tiktoken # Approximate token counter \(Gemini uses different tokeniser but close enough\) _enc =) Tj T* (tiktoken.get_encoding\("cl100k_base"\) def count_tokens\(text: str\) -> int: return len\(_enc.encode\(text\)\)) Tj T* (def compress_scene_context\(raw: str\) -> str: """ Typical savings: 45-55% fewer tokens on Godot .tscn) Tj T* (files. Run on your SCENE_CONTEXT string before every prompt. """ # 1. Strip XML/Godot comments out =) Tj T* (re.sub\(r";.*", "", raw\) # remove ; comments out = re.sub\(r"\\[node.*?]\\s* ", lambda m: m.group\(\).strip\(\) +) Tj T* (" ", out\) # 2. Collapse excess whitespace out = re.sub\(r" {2,}", " ", out\) out = re.sub\(r" {3,}", " ",) Tj T* (out\) # 3. Shorten verbose Godot class names \(saves 2-5 tokens each\) replacements = { "MeshInstance3D":) Tj T* ("MI3D", "CollisionShape3D": "CS3D", "CharacterBody3D": "CB3D", "DirectionalLight3D": "DL3D",) Tj T* ("WorldEnvironment": "WEnv", "NavigationAgent3D": "NavA", "AnimationPlayer": "AnimP",) Tj T* ("AudioStreamPlayer3D":"ASP3D", "GPUParticles3D": "GFX3D", "transform/position": "pos",) Tj T* ("transform/rotation": "rot", "transform/scale": "scl", } for long, short in replacements.items\(\): out =) Tj T* (out.replace\(long, short\) # 4. Remove UIDs \(not needed by AI\) out = re.sub\(r"uid="uid://[a-z0-9]+"", "",) Tj T* (out\) return out.strip\(\) def trim_history\(messages: list, max_tokens: int = 8000\) -> list: """ Keep only) Tj T* (messages that fit within token budget. Always keeps: system message \(index 0\) + last N messages. """ if) Tj T* (not messages: return messages system = [messages[0]] rest = messages[1:] total =) Tj T* (count_tokens\(messages[0].get\("content",""\)\) kept = [] for msg in reversed\(rest\): tokens =) Tj T* (count_tokens\(str\(msg.get\("content",""\)\)\) if total + tokens > max_tokens: break kept.insert\(0, msg\) total) Tj T* (+= tokens return system + kept) Tj T* ET
