BT 1 0 0 1 0 153.5 Tm /F5 7.5 Tf 11.5 TL (import json, pathlib from provider_gemini import gemini_complete MEMORY_DIR =) Tj T* (pathlib.Path\("saves/npc_memories"\) MEMORY_DIR.mkdir\(parents=True, exist_ok=True\) async def) Tj T* (compress_session\(npc_id: str, conversation_log: list[str]\) -> None: """Called at game save. Compresses) Tj T* (today's conversation into durable memories.""" prompt = \( "Summarise the most important things a) Tj T* (character should remember " "from this conversation log. Keep only facts that would change " "how they) Tj T* (behave in future interactions. Max 5 bullet points.\\n\\n" + "\\n".join\(conversation_log\) \) result = await) Tj T* (gemini_complete\(prompt, thinking="none"\) summary = result["text"] # Load existing memories, append new) Tj T* (summary mem_file = MEMORY_DIR / f"{npc_id}.txt" existing = mem_file.read_text\(\) if mem_file.exists\(\) else) Tj T* ("" # Keep only last 2000 chars of old memories to avoid bloat combined = \(existing[-2000:] + "\\n---\\n" +) Tj T* (summary\).strip\(\) mem_file.write_text\(combined\) def load_memory\(npc_id: str\) -> str: """Inject into system) Tj T* (prompt at session start.""" mem_file = MEMORY_DIR / f"{npc_id}.txt" if mem_file.exists\(\): return) Tj T* (f"\\n\\nYour memories of this player:\\n{mem_file.read_text\(\)}" return "" # Result: NPCs that say "Last time) Tj T* (you were here you mentioned your sister. # Did you ever find her?" -- across completely separate play) Tj T* (sessions.) Tj T* ET
