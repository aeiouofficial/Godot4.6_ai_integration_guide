BT 1 0 0 1 0 130.5 Tm /F3 7.5 Tf 11.5 TL (from provider_gemini import gemini_complete import json # You provide the world record splits and known) Tj T* (optimal routes WR_DATA = { "route_name": "any_percent_glitchless", "splits": [ {"name": "Forest Exit",) Tj T* ("wr_time_s": 142, "notes": "Skip the troll via west path"}, {"name": "Castle Entry", "wr_time_s": 318,) Tj T* ("notes": "Jump cancel on drawbridge"}, {"name": "Boss 1 Kill", "wr_time_s": 445, "notes": "Phase 2) Tj T* (stagger exploit"}, ] } async def coach_split\( split_name: str, player_time: float, player_deaths: int,) Tj T* (screenshot: str, \) -> str: wr_split = next\(\(s for s in WR_DATA["splits"] if s["name"] == split_name\),) Tj T* (None\) if not wr_split: return "" delta = player_time - wr_split["wr_time_s"] prompt = \( f"Speedrun) Tj T* (coaching for split: {split_name}\\n" f"Player time: {player_time:.1f}s | World record:) Tj T* ({wr_split['wr_time_s']}s | " f"Difference: {delta:+.1f}s\\n" f"Deaths: {player_deaths}\\n" f"WR notes:) Tj T* ({wr_split['notes']}\\n" "Give one specific, actionable coaching tip based on the screenshot. " "Keep it) Tj T* (under 2 sentences. Be encouraging but precise." \) result = await gemini_complete\(prompt, thinking="none",) Tj T* (image_path=screenshot\) return result["text"]) Tj T* ET
