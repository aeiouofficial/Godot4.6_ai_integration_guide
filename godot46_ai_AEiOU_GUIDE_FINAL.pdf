BT 1 0 0 1 0 234 Tm 11.5 TL /F5 7.5 Tf .803922 .839216 .956863 rg (extends Node ## Streams AI tokens in real time via Server-Sent Events. ## Connect token_received to) Tj T* (append text to a label or chat box. ## Connect stream_done when you need the full assembled response.) Tj T* (signal token_received\(token: String\) signal stream_done\(full_text: String\) signal stream_error\(message:) Tj T* (String\) const BRIDGE := "http://127.0.0.1:8000" var _http := HTTPClient.new\(\) var _full := "" var _active) Tj T* -0.198508 Tw (:= false var _buffer := "" func stream\(prompt: String, system: String = ""\) -> void: _full = ""; _buffer =) Tj T* 0 Tw (""; _active = true var err := _http.connect_to_host\("127.0.0.1", 8000\) if err != OK:) Tj T* (stream_error.emit\("Cannot connect to bridge: " + str\(err\)\) return set_process\(true\) var body :=) Tj T* (JSON.stringify\({"prompt": prompt, "system": system}\) var headers := ["Content-Type: application/json",) Tj T* ("Accept: text/event-stream"] _http.request\(HTTPClient.METHOD_POST, "/ai/stream", headers, body\) func) Tj T* (cancel\(\) -> void: _active = false; _http.close\(\); set_process\(false\) func _process\(_dt: float\) -> void:) Tj T* (_http.poll\(\) if not _active: return match _http.get_status\(\): HTTPClient.STATUS_BODY: var chunk :=) Tj T* (_http.read_response_body_chunk\(\) if chunk.size\(\) > 0: _buffer += chunk.get_string_from_utf8\(\)) Tj T* (_parse_buffer\(\) HTTPClient.STATUS_CONNECTED: pass # waiting for response headers) Tj T* (HTTPClient.STATUS_DISCONNECTED, HTTPClient.STATUS_CONNECTION_ERROR: _active = false; set_process\(false\)) Tj T* (if _full.length\(\) > 0: stream_done.emit\(_full\) _: pass func _parse_buffer\(\) -> void: # SSE lines look) Tj T* (like: "data: \\n\\n" while "\\n\\n" in _buffer: var end_idx := _buffer.find\("\\n\\n"\) var line :=) Tj T* (_buffer.substr\(0, end_idx\).strip_edges\(\) _buffer = _buffer.substr\(end_idx + 2\) if not) Tj T* (line.begins_with\("data: "\): continue var data := line.substr\(6\) if data == "[DONE]":) Tj T* (stream_done.emit\(_full\) _active = false; set_process\(false\) return if data.begins_with\("[ERR]"\):) Tj T* (stream_error.emit\(data.substr\(5\)\) _active = false; set_process\(false\) return # Decode RS \(0x1E\) back to) Tj T* (newlines var token := data.replace\(char\(30\), "\\n"\) _full += token token_received.emit\(token\)) Tj T* ET
