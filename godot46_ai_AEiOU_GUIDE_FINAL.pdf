BT 1 0 0 1 0 303 Tm /F3 7.5 Tf 11.5 TL (extends Node const BRIDGE := "http://127.0.0.1:8000" const TIMEOUT := 90.0 ## Emitted when the AI returns) Tj T* (a response. ## Connect this in any scene that needs AI output. signal response_received\(text: String,) Tj T* (provider: String\) ## Emitted if the HTTP call or JSON parsing fails. signal request_error\(message:) Tj T* (String\) ## Internal: pending request counter for UI spinners signal loading_changed\(is_loading: bool\) var) Tj T* (_pending := 0 ## Main entry point. Call from any script in your game. ## prompt: what to ask the AI ##) Tj T* (thinking: "none"|"minimal"|"medium"|"high" \227 controls reasoning depth ## provider:) Tj T* ("auto"|"gemini"|"glm-5"|"ollama" \227 usually leave as auto func ask\( prompt: String, thinking: String =) Tj T* ("medium", provider: String = "auto", \) -> void: _set_loading\(true\) var http := HTTPRequest.new\(\)) Tj T* (add_child\(http\) http.timeout = TIMEOUT http.request_completed.connect\(_on_done.bind\(http\)\) var body :=) Tj T* (JSON.stringify\({ "prompt": prompt, "thinking": thinking, "provider": provider, }\) var err :=) Tj T* (http.request\( BRIDGE + "/ai/complete", ["Content-Type: application/json"], HTTPClient.METHOD_POST, body\)) Tj T* (if err != OK: _set_loading\(false\) request_error.emit\("HTTPRequest failed: " + str\(err\)\) ## Convenience:) Tj T* (ask for scene commands \(returns JSON array\). ## Connect response_received and parse the JSON array) Tj T* (yourself, ## or pass to SceneBuilder.apply\(\). func ask_scene_commands\( instruction: String, provider:) Tj T* (String = "auto", \) -> void: var full := \(instruction + "\\nReturn ONLY a valid JSON array of scene) Tj T* (commands." + " Each object must have an action field: create, set, or delete." + " No explanation, no) Tj T* (markdown, just the JSON array."\) ask\(full, "medium", provider\) ## Check if the bridge server is reachable) Tj T* (before asking. func ping\(callback: Callable\) -> void: var http := HTTPRequest.new\(\) add_child\(http\)) Tj T* (http.timeout = 3.0 http.request_completed.connect\(func\(r,code,h,b\): http.queue_free\(\) callback.call\(code) Tj T* (== 200\)\) http.request\(BRIDGE + "/health"\) func _on_done\( _res, code: int, _h, body: PackedByteArray,) Tj T* (http: HTTPRequest \) -> void: http.queue_free\(\) _set_loading\(false\) if code != 200:) Tj T* (request_error.emit\("HTTP error " + str\(code\)\) return var json :=) Tj T* (JSON.parse_string\(body.get_string_from_utf8\(\)\) if json == null: request_error.emit\("Invalid JSON from) Tj T* (bridge"\) return var result = json.get\("result", json\) var text = result.get\("text",""\) if result is) Tj T* (Dictionary else str\(result\) var prov = json.get\("provider","?"\) response_received.emit\(text, prov\) func) Tj T* (_set_loading\(v: bool\) -> void: _pending = max\(0, _pending + \(1 if v else -1\)\)) Tj T* (loading_changed.emit\(_pending > 0\)) Tj T* ET
