BT 1 0 0 1 0 245.5 Tm /F3 7.5 Tf 11.5 TL (class AiReq\(BaseModel\): prompt: str system: str = "" thinking: str = Field\("medium",) Tj T* (pattern="^\(none|minimal|medium|high\)$"\) provider: str = Field\("auto",) Tj T* (pattern="^\(auto|gemini|glm-5|ollama\)$"\) class EnvPatch\(BaseModel\): patch: dict @app.get\("/health"\) async) Tj T* (def health\(\): return {"ok":True,"version":"1.0.0","ts":time.time\(\)} @app.get\("/providers"\) async def) Tj T* (providers\(\): """Returns which providers are currently reachable.""" from provider_router import) Tj T* (_ping_gemini,_ping_glm,_ping_ollama return { "gemini": await _ping_gemini\(\), "glm-5": await _ping_glm\(\),) Tj T* ("ollama": await _ping_ollama\(\), } @app.post\("/ai/complete"\) async def complete\(req: AiReq,) Tj T* (_=Depends\(rate_limit\)\): log.info\(f"complete: provider={req.provider} thinking={req.thinking}"\) if) Tj T* (req.provider != "auto": fns = {"gemini":"provider_gemini.gemini_complete",) Tj T* ("glm-5":"provider_glm.glm_complete", "ollama":"offline_handler.ollama_complete"} mod,fn =) Tj T* (fns[req.provider].rsplit\(".",1\) import importlib r = await) Tj T* (getattr\(importlib.import_module\(mod\),fn\)\(req.prompt,req.system\) return) Tj T* ({"provider":req.provider,"result":r} return await) Tj T* (route\(req.prompt,system=req.system,thinking=req.thinking\) @app.post\("/env/patch"\) async def) Tj T* (env_patch\(body: EnvPatch\): """VLM loop pushes patches here; Godot polls or WebSocket picks them up.""") Tj T* (log.info\(f"env/patch: {body.patch}"\) return {"status":"queued","patch":body.patch}) Tj T* (@app.post\("/scene/screenshot"\) async def trigger_screenshot\(\): """Ask Godot to take a screenshot via) Tj T* (MCP.""" return {"status":"screenshot_requested"} @app.get\("/metrics"\) async def metrics\(\): """Basic) Tj T* (metrics for monitoring.""" from provider_router import _fails return {"circuit_fails": {k:len\(v\) for k,v) Tj T* (in _fails.items\(\)}} if __name__ == "__main__": host = os.getenv\("BRIDGE_HOST","127.0.0.1"\) port =) Tj T* (int\(os.getenv\("BRIDGE_PORT","8000"\)\) log.info\(f"Starting bridge on {host}:{port}"\)) Tj T* (uvicorn.run\(app,host=host,port=port,reload=True, log_level=os.getenv\("LOG_LEVEL","info"\).lower\(\)\)) Tj T* ET
