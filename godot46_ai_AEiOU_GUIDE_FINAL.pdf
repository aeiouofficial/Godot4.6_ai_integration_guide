BT 1 0 0 1 0 406.5 Tm /F5 7.5 Tf 11.5 TL (from openai import AsyncOpenAI import os, json client = AsyncOpenAI\( api_key = os.environ["ZAI_API_KEY"],) Tj T* (base_url = "https://api.z.ai/api/paas/v4", \) GODOT_TOOLS = [) Tj T* ({"type":"function","function":{"name":"create_node", "description":"Create a node in the Godot scene.",) Tj T* ("parameters":{"type":"object","required":["type","name"],) Tj T* ("properties":{"type":{"type":"string"},"name":{"type":"string"},) Tj T* ("parent":{"type":"string","default":"."}, "props":{"type":"object"}}}}},) Tj T* ({"type":"function","function":{"name":"set_property", "description":"Set a property on a node.",) Tj T* ("parameters":{"type":"object","required":["path","property","value"],) Tj T* ("properties":{"path":{"type":"string"},"property":{"type":"string"}, "value":{"type":"string"}}}}},) Tj T* ({"type":"function","function":{"name":"attach_script", "description":"Write and attach a GDScript file to) Tj T* (a node.", "parameters":{"type":"object","required":["path","code"],) Tj T* ("properties":{"path":{"type":"string"},"code":{"type":"string"}, "filename":{"type":"string"}}}}},) Tj T* ({"type":"function","function":{"name":"delete_node", "description":"Delete a node from the scene.",) Tj T* ("parameters":{"type":"object","required":["path"], "properties":{"path":{"type":"string"}}}}}, ] class) Tj T* (GodotAgent: """ Stateful multi-turn GLM-5 agent with Preserved Thinking. The agent remembers its) Tj T* (reasoning across the entire session. """ def __init__\(self, game_context: str = ""\): self.history:) Tj T* (list[dict] = [] self.system = \( "You are an autonomous Godot 4.6 scene-building agent. " "Use the) Tj T* (available tools to build and modify the scene. " "Think carefully before each action. " "Remember your) Tj T* (plan across the entire conversation." \) if game_context: self.system += f"\\n\\nGame) Tj T* (context:\\n{game_context}" self.total_tokens = 0 async def step\( self, user_msg: str, complex_task: bool =) Tj T* (True, # False = skip thinking for simple ops \) -> dict: """One turn. Returns {actions, text, thinking,) Tj T* (tokens}.""" self.history.append\({"role":"user","content":user_msg}\) msgs =) Tj T* ([{"role":"system","content":self.system}] + self.history resp = await client.chat.completions.create\() Tj T* (model="glm-5", messages=msgs, tools=GODOT_TOOLS, tool_choice="auto", extra_body={ "thinking":) Tj T* ({"type":"enabled" if complex_task else "disabled"}, "clear_thinking": False, # Preserved Thinking --) Tj T* (never reset }, max_tokens=8192, temperature=0.2, \) msg = resp.choices[0].message actions = [] if) Tj T* (msg.tool_calls: actions = [ {"id": tc.id, "tool": tc.function.name, "args":) Tj T* (json.loads\(tc.function.arguments\)} for tc in msg.tool_calls ] self.history.append\({ "role": "assistant",) Tj T* ("content": None, "tool_calls": [tc.model_dump\(\) for tc in msg.tool_calls], }\) else:) Tj T* (self.history.append\({"role":"assistant","content":msg.content}\) self.total_tokens +=) Tj T* (resp.usage.total_tokens return { "actions": actions, "text": msg.content, "thinking":) Tj T* (getattr\(msg,"reasoning_content",None\), "tokens": resp.usage.total_tokens, } def add_tool_result\(self,) Tj T* (tool_id: str, result: str\) -> None: """Feed the result of a tool call back into the conversation.""") Tj T* (self.history.append\({ "role": "tool", "tool_call_id": tool_id, "content": result, }\) def summary\(self\) ->) Tj T* (str: return \(f"Session: {len\(self.history\)} turns, {self.total_tokens} total tokens,) Tj T* (${self.total_tokens/1_000_000:.4f} cost"\)) Tj T* ET
