BT 1 0 0 1 0 176.5 Tm /F5 7.5 Tf 11.5 TL (import asyncio from glm_agent import GodotAgent # execute_tool\(\) sends commands to Godot via MCP) Tj T* (WebSocket from bridge_server import execute_tool async def build_dungeon_level\(\): agent =) Tj T* (GodotAgent\(game_context=""" Dark fantasy dungeon crawler. Art direction: stone walls, torchlight, deep) Tj T* (shadows. Parent for all level geometry: /World/Level """\) # Turn 1 -- complex planning, thinking enabled) Tj T* (r1 = await agent.step\( "Design a dungeon room: 10m\32710m stone chamber with 4 corners, " "2 torches on) Tj T* (opposite walls, a locked iron door, and bone debris on the floor. " "Start building it now.",) Tj T* (complex_task=True \) for action in r1["actions"]: result = await execute_tool\(action["tool"],) Tj T* (action["args"]\) agent.add_tool_result\(action["id"], str\(result\)\) print\(f"[T1] {len\(r1['actions']\)}) Tj T* (actions, thinking: {bool\(r1['thinking']\)}"\) # Turn 2 -- simple property tweak, disable thinking for speed) Tj T* (r2 = await agent.step\( "Set both torches to orange colour temp 2200K and energy 2.0.", complex_task=False) Tj T* (# ~1s instead of ~8s \) for action in r2["actions"]: result = await execute_tool\(action["tool"],) Tj T* (action["args"]\) agent.add_tool_result\(action["id"], str\(result\)\) # Turn 3 -- complex: add atmosphere,) Tj T* (thinking re-enabled r3 = await agent.step\( "Add subtle fog and a faint dripping sound. " "Also check if) Tj T* (anything looks wrong with the layout so far.", complex_task=True \) for action in r3["actions"]: result =) Tj T* (await execute_tool\(action["tool"], action["args"]\) agent.add_tool_result\(action["id"], str\(result\)\)) Tj T* (print\(agent.summary\(\)\) asyncio.run\(build_dungeon_level\(\)\)) Tj T* ET
