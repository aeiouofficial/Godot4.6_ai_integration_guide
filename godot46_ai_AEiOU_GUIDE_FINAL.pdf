BT 1 0 0 1 0 165 Tm /F3 7.5 Tf 11.5 TL (from openai import AsyncOpenAI import os, json from dotenv import load_dotenv load_dotenv\(\) # GLM-5 is) Tj T* (fully OpenAI-SDK compatible client = AsyncOpenAI\( api_key = os.environ["ZAI_API_KEY"], base_url =) Tj T* ("https://api.z.ai/api/paas/v4", \) MODEL = "glm-5" async def glm_complete\( prompt: str, system: str = "",) Tj T* (thinking: bool = True, tools: list|None = None, history: list|None = None, # for multi-turn agents \) ->) Tj T* (dict: """ thinking=True ) Tj /F5 7.5 Tf 11.5 TL (\256) Tj /F3 7.5 Tf 11.5 TL ( Preserved Thinking enabled \(clear_thinking=False\) history ) Tj /F5 7.5 Tf 11.5 TL (\256) Tj /F3 7.5 Tf 11.5 TL ( pass previous) Tj T* (messages for multi-turn sessions """ if history: msgs = [{"role":"system","content":system or "You are a) Tj T* (Godot 4.6 expert."}] msgs.extend\(history\) msgs.append\({"role":"user","content":prompt}\) else: msgs = [) Tj T* ({"role":"system","content":system or "You are a Godot 4.6 expert."}, {"role":"user","content":prompt}, ]) Tj T* (extra: dict = {} if thinking: extra["thinking"] = {"type": "enabled"} extra["clear_thinking"] = False #) Tj T* (Preserved Thinking \227 retain across turns kw = dict\(model=MODEL, messages=msgs, temperature=0.2,) Tj T* (max_tokens=8192, **extra\) if tools: kw["tools"] = tools; kw["tool_choice"] = "auto" resp = await) Tj T* (client.chat.completions.create\(**kw\) msg = resp.choices[0].message if msg.tool_calls: tc =) Tj T* (msg.tool_calls[0] return { "tool": tc.function.name, "args": json.loads\(tc.function.arguments\),) Tj T* ("thinking": getattr\(msg,"reasoning_content",None\), "model": MODEL, } return { "text": msg.content,) Tj T* ("thinking": getattr\(msg,"reasoning_content",None\), "tokens": resp.usage.total_tokens, "model": MODEL, }) Tj T* ET
