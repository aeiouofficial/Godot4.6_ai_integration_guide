BT 1 0 0 1 0 153.5 Tm /F5 7.5 Tf 11.5 TL (import json, pathlib from provider_gemini import gemini_complete BIBLE_FILE =) Tj T* (pathlib.Path\("saves/world_bible.json"\) def load_bible\(\) -> dict: return) Tj T* (json.loads\(BIBLE_FILE.read_text\(\)\) if BIBLE_FILE.exists\(\) else {} def save_bible\(bible: dict\) -> None:) Tj T* (BIBLE_FILE.write_text\(json.dumps\(bible, indent=2\)\) async def expand_on_discovery\(area_name: str,) Tj T* (visual_description: str\) -> str: """ Player discovers a new area. AI writes its history into the world) Tj T* (bible. Returns flavour text for an in-game book or journal entry. """ bible = load_bible\(\) existing_lore) Tj T* (= json.dumps\(bible, indent=2\)[:3000] # cap context prompt = \( f"Add to the world lore. Existing world) Tj T* (bible:\\n{existing_lore}\\n\\n" f"The player just discovered: {area_name}\\n" f"Visual description:) Tj T* ({visual_description}\\n" "Write: \(1\) a 2-paragraph history for this area that fits the existing lore, ") Tj T* ("\(2\) a rumour locals might tell, \(3\) a short journal entry an explorer left here. " "Return JSON:) Tj T* ({history:str, rumour:str, journal_entry:str, " "new_lore_key:str, new_lore_value:str}" \) result = await) Tj T* (gemini_complete\(prompt, thinking="medium"\) data = json.loads\(result["text"]\) # Expand the bible with the) Tj T* (new lore entry bible[data["new_lore_key"]] = data["new_lore_value"] save_bible\(bible\) return) Tj T* (data["journal_entry"] # show this in a Godot popup) Tj T* ET
