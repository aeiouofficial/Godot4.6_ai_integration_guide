BT 1 0 0 1 0 130.5 Tm /F3 7.5 Tf 11.5 TL (import pathlib, asyncio from provider_gemini import gemini_complete async def) Tj T* (check_consistency\(content_dir: str\) -> list[dict]: """ Scan all .txt/.json content files for narrative) Tj T* (contradictions. Returns a list of {file, issue, severity} dicts. Run before every content patch ship. """) Tj T* (content_dir_p = pathlib.Path\(content_dir\) all_text = "" file_map = {} for f in) Tj T* (content_dir_p.rglob\("*.txt"\): text = f.read_text\(\)[:2000] file_map[f.name] = text all_text += f"\\n\\n===) Tj T* ({f.name} ===\\n{text}" prompt = \( "You are a narrative editor. Review this game content for:\\n" "1.) Tj T* (Factual contradictions \(NPC says X in one file, not-X in another\)\\n" "2. Timeline inconsistencies\\n" "3.) Tj T* (Character voice inconsistencies \(same NPC sounds different\)\\n" "4. Lore conflicts\\n\\n" "Content:\\n" +) Tj T* (all_text[:30000] \) result = await gemini_complete\(prompt, thinking="high"\) return result["text"] if) Tj T* (__name__ == "__main__": findings = asyncio.run\(check_consistency\("res://data/dialogue"\)\) print\(findings\)) Tj T* (# Run weekly before patch day. Catches the "Mira died in Act 1 but # appears in Act 3" type of error) Tj T* (automatically.) Tj T* ET
