BT 1 0 0 1 0 153.5 Tm /F3 7.5 Tf 11.5 TL (import json, pathlib, time PREF_FILE = pathlib.Path\("data/ai_preferences.jsonl"\) def record_preference\() Tj T* (prompt: str, response: str, signal: str, # "liked", "skipped", "replayed", "ignored" context: dict, \) ->) Tj T* (None: """ Record implicit feedback on AI responses. signal sources: "liked" -- player pressed a "remember) Tj T* (this" button "replayed" -- player opened dialogue history "skipped" -- player mashed through text quickly) Tj T* ("ignored" -- NPC dialogue triggered but player walked away """ entry = { "ts": time.time\(\), "prompt":) Tj T* (prompt[:500], "response":response[:500], "signal": signal, "context": context, } with PREF_FILE.open\("a"\)) Tj T* (as f: f.write\(json.dumps\(entry\) + "\\n"\) async def analyse_preferences\(\) -> str: """Weekly: feed) Tj T* (preference data to AI, get better system prompts.""" from provider_gemini import gemini_complete entries) Tj T* (= [json.loads\(l\) for l in PREF_FILE.read_text\(\).splitlines\(\)[-200:]] liked = [e for e in entries if) Tj T* (e["signal"] in \("liked","replayed"\)] skipped = [e for e in entries if e["signal"] in) Tj T* (\("skipped","ignored"\)] prompt = \( f"Players liked these {len\(liked\)} AI responses and " f"skipped/ignored) Tj T* (these {len\(skipped\)}.\\n" "Analyse what makes the liked ones better. " "Suggest a revised system prompt) Tj T* (that produces more of the liked style." \) result = await gemini_complete\(prompt, thinking="high"\) return) Tj T* (result["text"]) Tj T* ET
