BT 1 0 0 1 0 176.5 Tm /F3 7.5 Tf 11.5 TL (extends Node3D ## AI-driven prop placement based on biome, elevation, and proximity data. ## Produces) Tj T* (organic-looking environments without hand-placing every asset. @export var biome: String = "forest") Tj T* (@export var area_size: Vector2 = Vector2\(50, 50\) @export var prop_budget: int = 30 var _prop_library := {) Tj T* ("forest": ["tree_oak","tree_pine","bush_fern","rock_moss","log_fallen"], "desert":) Tj T* (["cactus_tall","cactus_squat","rock_sandstone","dead_tree","tumbleweed"], "dungeon":) Tj T* (["torch_wall","barrel","crate","bones","stalagmite","puddle"], } func populate\(\) -> void: var available) Tj T* (:= _prop_library.get\(biome, []\) var prompt := \( "Place %d props in a %s area of %s meters. " %) Tj T* ([prop_budget, biome, area_size] + "Available props: " + JSON.stringify\(available\) + "\\n" + "Place them) Tj T* (naturally -- cluster plants near water, " + "scatter rocks, make groups look organic not grid-like. " +) Tj T* ("Return JSON array: [{prop: string, x: float, z: float, rot_y: float, scale: float}]" \)) Tj T* (AIAgent.response_received.connect\(_on_placement, CONNECT_ONE_SHOT\) AIAgent.ask\(prompt, "medium"\) func) Tj T* (_on_placement\(text: String, _p: String\) -> void: var s := text.find\("["\); var e := text.rfind\("]"\)+1 if s) Tj T* (== -1: return var placements = JSON.parse_string\(text.substr\(s,e-s\)\) if not placements is Array: return) Tj T* (for p in placements: var scene := load\("res://assets/props/" + p.prop + ".tscn"\) as PackedScene if not) Tj T* (scene: continue var node := scene.instantiate\(\) node.position = Vector3\(p.x, 0, p.z\) node.rotation.y =) Tj T* (deg_to_rad\(p.get\("rot_y", 0.0\)\) node.scale = Vector3.ONE * p.get\("scale", 1.0\) add_child\(node\)) Tj T* ET
