BT 1 0 0 1 0 188 Tm /F3 7.5 Tf 11.5 TL (from google import genai from google.genai import types import json, pathlib, os client =) Tj T* (genai.Client\(api_key=os.environ["GEMINI_API_KEY"]\) def submit_batch\(tasks: list[dict], job_name: str =) Tj T* ("godot-batch"\) -> str: """ tasks format: [{"id": "task_1", "prompt": "...", "system": "..."}] Returns:) Tj T* (job_name to poll later. Cost: 50% of standard pricing. Turnaround: up to 24 hours. Best for: lore) Tj T* (generation, item descriptions, translation, screenshot audits. """ requests = [] for task in tasks:) Tj T* (requests.append\({ "request_id": task["id"], "model": "models/gemini-3-flash-preview", "contents":) Tj T* ([{"parts": [{"text": task["prompt"]}]}], "system_instruction": {"parts": [{"text":) Tj T* (task.get\("system",""\)}]}, }\) tmp = pathlib.Path\("/tmp/batch_input.jsonl"\) tmp.write_text\(") Tj T* (".join\(json.dumps\(r\) for r in requests\)\) uploaded = client.files.upload\(file=str\(tmp\)\) job =) Tj T* (client.batches.create\( model="models/gemini-3-flash-preview", src=uploaded.name,) Tj T* (config=types.CreateBatchJobConfig\(display_name=job_name\), \) print\(f"[Batch] Submitted {len\(tasks\)} tasks) Tj T* (as job: {job.name}"\) return job.name def poll_batch\(job_name: str\) -> list[dict] | None: """Poll until) Tj T* (complete. Returns None if still running.""" job = client.batches.get\(name=job_name\) if job.state.name not) Tj T* (in \("JOB_STATE_SUCCEEDED", "JOB_STATE_FAILED"\): print\(f"[Batch] State: {job.state.name} -- still) Tj T* (processing"\) return None if job.state.name == "JOB_STATE_FAILED": raise RuntimeError\(f"Batch job failed:) Tj T* ({job.error}"\) # Download results results = [] for line in) Tj T* (client.files.download\(job.dest\).decode\(\).splitlines\(\): results.append\(json.loads\(line\)\) return results) Tj T* ET
