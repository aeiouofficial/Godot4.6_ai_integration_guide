BT 1 0 0 1 0 349 Tm /F3 7.5 Tf 11.5 TL (extends Node ## Applies AI-generated scene command arrays to the live scene tree. ## Supports rollback:) Tj T* (undo all changes since last checkpoint. # Godot 4.6: track nodes by stable instance ID \(survives) Tj T* (rename/reparent\) var _id_map: Dictionary = {} # name ) Tj /F5 7.5 Tf 11.5 TL (\256) Tj /F3 7.5 Tf 11.5 TL ( instance_id var _snapshots: Array = [] # rollback) Tj T* (stack ## Apply a JSON array of scene commands from the AI. ## Call after parsing AI response \227 see) Tj T* (ai_agent.gd usage example. func apply\(commands: Array\) -> Dictionary: """Returns {ok: bool, applied: int,) Tj T* (errors: Array}""" var result := {"ok":true,"applied":0,"errors":[]} for cmd in commands: var err :=) Tj T* (_exec\(cmd\) if err: result.errors.append\(err\) result.ok = false else: result.applied += 1 return result ##) Tj T* (Snapshot current scene state for rollback. func checkpoint\(\) -> void:) Tj T* (_snapshots.append\(_id_map.duplicate\(deep=true\)\) ## Undo all changes since last checkpoint. func) Tj T* (rollback\(\) -> void: if _snapshots.is_empty\(\): return var snap: Dictionary = _snapshots.pop_back\(\) #) Tj T* (Remove nodes created after snapshot for name in _id_map.keys\(\): if name not in snap: var id: int =) Tj T* (_id_map[name] var node := instance_from_id\(id\) if node: node.queue_free\(\) _id_map = snap func _exec\(cmd:) Tj T* (Dictionary\) -> String: match cmd.get\("action","create"\): "create": return _create\(cmd\) "set": return) Tj T* (_set\(cmd\) "delete": return _delete\(cmd\) return "Unknown action: " + cmd.get\("action",""\) func) Tj T* (_create\(cmd: Dictionary\) -> String: var cls_name: String = cmd.get\("type","Node"\) if not) Tj T* (ClassDB.class_exists\(cls_name\): return "Unknown class: " + cls_name var node =) Tj T* (ClassDB.instantiate\(cls_name\) node.name = cmd.get\("name","AINode"\) var parent_path: String =) Tj T* (cmd.get\("parent","."\) var parent := get_node_or_null\(parent_path\) if not parent: node.queue_free\(\) return) Tj T* ("Parent not found: " + parent_path parent.add_child\(node\) # GODOT 4.6: set owner so node persists in) Tj T* (saved scenes node.owner = get_tree\(\).edited_scene_root # Track by Unique Node ID \227 stable across) Tj T* (rename/reparent _id_map[node.name] = node.get_instance_id\(\) # Apply initial properties for k in) Tj T* (cmd.get\("props",{}\).keys\(\): if node.get\(k\) != null: node.set\(k, cmd.props[k]\) else:) Tj T* (push_warning\("[SceneBuilder] Ignored unknown prop: " + k\) return "" func _set\(cmd: Dictionary\) -> String:) Tj T* (var node := get_node_or_null\(cmd.get\("path",""\)\) if not node: return "Node not found: " +) Tj T* (cmd.get\("path",""\) var prop: String = cmd.get\("property",""\) if node.get\(prop\) == null and not) Tj T* (prop.contains\("/"\): return "Unknown property " + prop + " on " + node.name node.set\(prop,) Tj T* (cmd.get\("value"\)\) return "" func _delete\(cmd: Dictionary\) -> String: var node :=) Tj T* (get_node_or_null\(cmd.get\("path",""\)\) if not node: return "Node not found: " + cmd.get\("path",""\)) Tj T* (_id_map.erase\(node.name\) node.queue_free\(\) return "" ## Get a previously AI-created node by name using) Tj T* (Unique ID. ## Survives rename and reparenting \227 unlike get_node\("path"\). func get_ai_node\(name: String\)) Tj T* (-> Node: if name not in _id_map: return null return instance_from_id\(_id_map[name]\)) Tj T* ET
