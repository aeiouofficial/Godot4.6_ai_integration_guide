BT 1 0 0 1 0 107.5 Tm /F3 7.5 Tf 11.5 TL (import httpx, os, asyncio from dotenv import load_dotenv load_dotenv\(\) OLLAMA_URL =) Tj T* (os.getenv\("OLLAMA_URL", "http://localhost:11434"\) OLLAMA_MODEL = os.getenv\("OLLAMA_MODEL", "glm4"\) async) Tj T* (def ollama_complete\(prompt: str, system: str = "", **_\) -> str: payload = { "model": OLLAMA_MODEL,) Tj T* ("prompt": prompt, "system": system or "You are a Godot 4.6 expert. Be concise.", "stream": False,) Tj T* ("options": { "temperature": 0.2, "num_predict": 4096, "num_ctx": 32768, # 32K context is safe for) Tj T* (GLM-4.7-Flash "repeat_penalty":1.1, # reduce repetition "top_p": 0.9, }, } async with) Tj T* (httpx.AsyncClient\(timeout=120\) as c: r = await c.post\(f"{OLLAMA_URL}/api/generate", json=payload\)) Tj T* (r.raise_for_status\(\) return r.json\(\)["response"] async def ollama_health\(\) -> bool: try: async with) Tj T* (httpx.AsyncClient\(timeout=2\) as c: r = await c.get\(f"{OLLAMA_URL}/api/tags"\) return r.status_code == 200) Tj T* (except: return False) Tj T* ET
